---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SundayRec — Automated Church Recording Software',
  description = 'SundayRec automatically records your Sunday services and prepares them for podcast distribution. Free for churches — Mac & Windows.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_primary_32px.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_primary_16px.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png" />

    <!-- Canonical -->
    <link rel="canonical" href="https://sundayrec.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://sundayrec.com/images/og_primary_1200x630.png" />
    <meta property="og:url" content="https://sundayrec.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SundayRec" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://sundayrec.com/images/og_primary_1200x630.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
