---
import Layout from '../layouts/Layout.astro';

const VERSION = 'v4.54.0';
---

<Layout>
  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="#" class="flex items-center gap-3">
        <img src="/images/sundayrec_primary_gull-paa-blaa.svg" alt="SundayRec" class="w-10 h-10" />
        <span class="font-bold text-lg text-[#194280]">SundayRec</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#features" class="hover:text-[#194280] transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-[#194280] transition-colors">How it works</a>
        <a href="#pricing" class="hover:text-[#194280] transition-colors">Pricing</a>
        <a href="#download" class="hover:text-[#194280] transition-colors">Download</a>
        <a href="#contact" class="hover:text-[#194280] transition-colors">Contact</a>
      </nav>
      <a
        href="#download"
        class="hidden md:inline-flex bg-[#F0BB47] hover:bg-[#f5cc6f] text-[#194280] font-semibold text-sm px-5 py-2.5 rounded-full transition-colors"
      >
        Download Free
      </a>
      <button id="nav-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="w-5 h-0.5 bg-[#194280] block"></span>
        <span class="w-5 h-0.5 bg-[#194280] block"></span>
        <span class="w-5 h-0.5 bg-[#194280] block"></span>
      </button>
    </div>
  </header>

  <!-- Mobile nav -->
  <div id="nav-menu" class="fixed top-16 inset-x-0 bg-white border-b border-gray-200 z-40 hidden">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1 text-sm font-medium text-gray-600">
      <a href="#features" class="hover:text-[#194280] transition-colors py-2.5 border-b border-gray-50">Features</a>
      <a href="#how-it-works" class="hover:text-[#194280] transition-colors py-2.5 border-b border-gray-50">How it works</a>
      <a href="#pricing" class="hover:text-[#194280] transition-colors py-2.5 border-b border-gray-50">Pricing</a>
      <a href="#download" class="hover:text-[#194280] transition-colors py-2.5 border-b border-gray-50">Download</a>
      <a href="#contact" class="hover:text-[#194280] transition-colors py-2.5 border-b border-gray-50">Contact</a>
      <a href="#download" class="mt-3 bg-[#F0BB47] hover:bg-[#f5cc6f] text-[#194280] font-semibold px-5 py-3 rounded-full transition-colors text-center">
        Download Free
      </a>
    </nav>
  </div>
  <script>
    const navToggle = document.getElementById('nav-toggle')
    const navMenu   = document.getElementById('nav-menu')
    navToggle?.addEventListener('click', () => navMenu?.classList.toggle('hidden'))
    navMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navMenu?.classList.add('hidden')))
  </script>

  <!-- HERO -->
  <section class="pt-32 pb-24 bg-[#194280] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-20 left-10 w-96 h-96 rounded-full bg-[#F0BB47] blur-3xl"></div>
      <div class="absolute bottom-0 right-10 w-80 h-80 rounded-full bg-white blur-3xl"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative">
      <!-- Live badge -->
      <div class="flex justify-center mb-8">
        <span class="inline-flex items-center gap-2 bg-[#F0BB47]/20 border border-[#F0BB47]/40 text-[#F0BB47] text-sm font-semibold px-4 py-2 rounded-full">
          <span class="w-2 h-2 rounded-full bg-[#F0BB47] animate-pulse"></span>
          {VERSION} · Record · Stream · Transcribe · Publish
        </span>
      </div>

      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-extrabold text-white leading-tight mb-6">
          Your sermon,<br />
          <span class="text-[#F0BB47]">ready to share.</span>
        </h1>
        <p class="text-xl md:text-2xl text-blue-200 max-w-2xl mx-auto mb-4 leading-relaxed">
          Set the schedule once. Every Sunday, SundayRec records the service, transcribes the sermon, streams it live, and publishes to your podcast — by itself.
        </p>
        <p class="text-base md:text-lg text-blue-300/80 max-w-2xl mx-auto mb-10 leading-relaxed">
          Free desktop app for Mac & Windows. No subscription. No cloud relay. Your files stay yours.
        </p>

        <!-- Email capture -->
        <div id="early-access" class="max-w-md mx-auto">
          <p class="text-blue-300 text-sm mb-3 font-medium">Get notified about major SundayRec releases</p>
          <form
            action="https://formspree.io/f/3004580849401199888"
            method="POST"
            class="flex flex-col sm:flex-row gap-3"
          >
            <input
              type="email"
              name="email"
              placeholder="your@church.com"
              required
              class="flex-1 px-5 py-3.5 rounded-full bg-white/10 border border-white/20 text-white placeholder-blue-300 focus:outline-none focus:border-[#F0BB47] focus:bg-white/15 transition-all text-sm"
            />
            <button
              type="submit"
              class="bg-[#F0BB47] hover:bg-[#f5cc6f] text-[#194280] font-bold px-7 py-3.5 rounded-full transition-colors text-sm whitespace-nowrap"
            >
              Notify Me
            </button>
          </form>
          <p class="text-blue-400 text-xs mt-3">No spam. Unsubscribe anytime.</p>
        </div>

        <!-- Beta download CTA -->
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <span class="text-blue-300 text-sm">Free, full-featured, no account needed:</span>
          <div class="flex gap-3">
            <a
              href="https://github.com/richardfossland/sundayrec/releases"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              Mac
            </a>
            <a
              href="https://github.com/richardfossland/sundayrec/releases"
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white px-5 py-2.5 rounded-full text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 5.557L10.025 4.5v7.003H3V5.557zM10.025 12.497H3V18.443L10.025 19.5v-7.003zM10.975 4.368L21 2.997v8.506h-10.025V4.368zM21 13.497H10.975v8.135L21 20.003v-6.506z"/>
              </svg>
              Windows
            </a>
          </div>
        </div>
      </div>

      <!-- Hero visual / app mockup -->
      <div class="mt-20 flex justify-center">
        <div class="relative w-full max-w-3xl">
          <div class="bg-[#0f2a54] rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
            <div class="flex items-center gap-2 px-5 py-4 border-b border-white/10 bg-[#0d2348]">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
              </div>
              <div class="flex-1 text-center">
                <span class="text-white/40 text-xs font-mono">SundayRec</span>
              </div>
            </div>
            <div class="p-8">
              <div class="grid grid-cols-3 gap-4 mb-6">
                <div class="bg-white/5 rounded-xl p-4 border border-white/10">
                  <div class="text-[#F0BB47] text-xs font-semibold mb-2 uppercase tracking-wide">Next Recording</div>
                  <div class="text-white text-xl font-bold">Sunday</div>
                  <div class="text-blue-300 text-sm">10:00 AM</div>
                </div>
                <div class="bg-white/5 rounded-xl p-4 border border-white/10">
                  <div class="text-[#F0BB47] text-xs font-semibold mb-2 uppercase tracking-wide">Last Recording</div>
                  <div class="text-white text-xl font-bold">1:04:33</div>
                  <div class="text-blue-300 text-sm">MP3 · 192 kbps</div>
                </div>
                <div class="bg-white/5 rounded-xl p-4 border border-white/10">
                  <div class="text-[#F0BB47] text-xs font-semibold mb-2 uppercase tracking-wide">Status</div>
                  <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
                    <span class="text-white font-bold">Ready</span>
                  </div>
                  <div class="text-blue-300 text-sm">Scheduled</div>
                </div>
              </div>
              <div class="bg-white/5 rounded-xl p-4 border border-white/10">
                <div class="text-white/40 text-xs font-semibold mb-3 uppercase tracking-wide">Audio waveform</div>
                <div class="flex items-end gap-0.5 h-14 px-1">
                  {[28,35,42,38,25,48,52,45,30,22,40,55,60,50,35,28,44,58,62,55,40,32,48,52,45,30,22,38,50,55,48,35,28,42,58,65,58,44,30,25,40,52,58,50,38,28,44,55,60,52,38,30,45,58,62,55,42,32,48,55].map((h) => (
                    <div
                      class="flex-1 bg-[#F0BB47] rounded-sm opacity-70"
                      style={`height: ${h}px`}
                    ></div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IT DOES — concrete capabilities, no jargon -->
  <section class="py-20 bg-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="text-[#F0BB47] font-semibold text-sm uppercase tracking-widest">What it does</span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-[#194280] mt-3 mb-4">
          One app. The whole Sunday workflow.
        </h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">
          From the moment the service starts to the podcast going live — SundayRec handles every step so your team doesn't have to remember.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Records -->
        <div class="bg-gradient-to-br from-[#194280] to-[#0f2a54] p-7 rounded-2xl text-white relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full bg-[#F0BB47]/10 blur-2xl"></div>
          <div class="w-12 h-12 bg-[#F0BB47]/20 rounded-xl flex items-center justify-center mb-5 relative">
            <svg class="w-6 h-6 text-[#F0BB47]" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="6"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2 relative">Records audio &amp; video</h3>
          <p class="text-blue-200 text-sm leading-relaxed relative">From your USB mixer, audio interface, webcam or HDMI capture card. Lossless or MP3. Auto-start on Sunday morning.</p>
        </div>

        <!-- Streams -->
        <div class="bg-gradient-to-br from-[#194280] to-[#0f2a54] p-7 rounded-2xl text-white relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full bg-red-500/10 blur-2xl"></div>
          <div class="w-12 h-12 bg-red-500/20 rounded-xl flex items-center justify-center mb-5 relative">
            <svg class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2 relative">Streams live</h3>
          <p class="text-blue-200 text-sm leading-relaxed relative">To YouTube, Facebook Live, or any RTMP server — multiple destinations at once. Stream and record at the same time.</p>
        </div>

        <!-- Transcribes -->
        <div class="bg-gradient-to-br from-[#194280] to-[#0f2a54] p-7 rounded-2xl text-white relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full bg-green-500/10 blur-2xl"></div>
          <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-5 relative">
            <svg class="w-6 h-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2 relative">Transcribes the sermon</h3>
          <p class="text-blue-200 text-sm leading-relaxed relative">On-device AI converts every sermon to searchable text in 8 languages. Nothing leaves your computer. Exports SRT subtitles.</p>
        </div>

        <!-- Publishes -->
        <div class="bg-gradient-to-br from-[#194280] to-[#0f2a54] p-7 rounded-2xl text-white relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 rounded-full bg-[#F0BB47]/15 blur-2xl"></div>
          <div class="w-12 h-12 bg-[#F0BB47]/20 rounded-xl flex items-center justify-center mb-5 relative">
            <svg class="w-6 h-6 text-[#F0BB47]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2 relative">Publishes the podcast</h3>
          <p class="text-blue-200 text-sm leading-relaxed relative">Auto-uploads to Google Drive or Dropbox, generates a podcast RSS feed for Spotify, Apple Podcasts and Pocket Casts.</p>
        </div>
      </div>

      <!-- Quick-fact strip -->
      <div class="mt-14 pt-10 border-t border-gray-100">
        <p class="text-gray-400 text-sm font-medium mb-6 uppercase tracking-widest text-center">Built for churches across Europe</p>
        <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 items-center">
          {[
            'Free forever',
            'Mac & Windows',
            '7 interface languages',
            'No subscription',
            'No account required',
            'Works offline',
            'Open release notes',
          ].map(item => (
            <span class="flex items-center gap-2 text-gray-500 text-sm font-medium">
              <svg class="w-4 h-4 text-[#F0BB47] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-[#F0BB47] font-semibold text-sm uppercase tracking-widest">All the details</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#194280] mt-3 mb-4">
          Every feature your church needs
        </h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto">
          Built specifically for the Sunday morning team — from setup wizard to broadcast-grade audio mastering. No subscriptions. No locked features.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Automatic Scheduling -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-[#194280]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#194280] transition-colors">
            <svg class="w-6 h-6 text-[#194280] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#194280] mb-2">Automatic scheduling</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Set your service time once. SundayRec wakes the computer (Mac & Windows OS-level wake), starts ffmpeg, and stops when the service is over — every week, by itself.</p>
        </div>

        <!-- USB Mixer -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-[#194280]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#194280] transition-colors">
            <svg class="w-6 h-6 text-[#194280] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#194280] mb-2">USB mixer & ASIO support</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Detects any USB mixer or audio interface automatically. Native ASIO on Windows for low-latency professional setups. Pre-roll buffer catches the first words even before recording starts.</p>
        </div>

        <!-- Video / Capture / NDI -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all relative">
          <div class="absolute top-4 right-4">
            <span class="bg-[#F0BB47]/20 text-[#194280] text-xs font-bold px-2 py-1 rounded-full">v4.44+</span>
          </div>
          <div class="w-12 h-12 bg-[#194280]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#194280] transition-colors">
            <svg class="w-6 h-6 text-[#194280] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#194280] mb-2">Video, capture cards & NDI</h3>
          <p class="text-gray-500 text-sm leading-relaxed">USB webcam, HDMI capture (Blackmagic, Elgato, Magewell), and native NDI receiver for ProPresenter, OBS, Keynote/PowerPoint via Screen Capture HX. No third-party drivers needed.</p>
        </div>

        <!-- Live overlays -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all relative">
          <div class="absolute top-4 right-4">
            <span class="bg-[#F0BB47]/20 text-[#194280] text-xs font-bold px-2 py-1 rounded-full">v4.43+</span>
          </div>
          <div class="w-12 h-12 bg-[#194280]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#194280] transition-colors">
            <svg class="w-6 h-6 text-[#194280] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#194280] mb-2">Live overlays</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Layer images, screen captures, app windows, or NDI feeds over your video — with chroma key, 9-grid positioning, and per-overlay opacity. ProPresenter lyrics on top of the camera with a single click.</p>
        </div>

        <!-- Live Streaming -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all">
          <div class="w-12 h-12 bg-red-500/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-red-500 transition-colors">
            <svg class="w-6 h-6 text-red-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-[#194280] mb-2">Live RTMP streaming</h3>
          <p class="text-gray-500 text-sm leading-relaxed">YouTube, Facebook Live, or any RTMP server — multiple destinations at the same time from a single ffmpeg process. 480p / 720p / 1080p, 25 or 30 fps. Stream-keys encrypted in the keychain.</p>
        </div>

        <!-- Stream + record simultaneously -->
        <div class="group bg-white p-7 rounded-2xl border border-gray-100 hover:border-[#194280]/20 hover:shadow-lg transition-all relative">
          <div class="absolute top-4 right-4">
            <span class="bg-[#F0BB47]/20 text-[#194280] text-xs font-bold px-2 py-1 rounded-full">v4.46+</span>
          </div>
          <div class="w-12 h-12 bg-[#194280]/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-[#194280] transition-colors">
